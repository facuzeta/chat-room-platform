# Copy this file to .env and fill in the values before running docker compose

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1
DOMAIN=localhost

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatroom

# Django superuser (created on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# Static files volume mount path inside the container
STATIC_DIR=/usr/src/app/staticfiles

# Email — leave blank to use the console backend in DEBUG mode
EMAIL_HOST=
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_ADDRESS=noreply@example.com
EMAIL=noreply@example.com

# Bot LLM backends (only needed if you use those models)
OPEN_AI_API_KEY=
EXTERNAL_OLLAMA_KEY=
EXTERNAL_OLLAMA_URL=
